# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-this-to-a-secure-random-string-in-production
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — development)
DATABASE_URL=sqlite+aiosqlite:///./data/hwai.db

# PostgreSQL (production) — uncomment and fill in when switching
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hwai
# POSTGRES_DB=hwai
# POSTGRES_USER=hwai
# POSTGRES_PASSWORD=

# ── AI / Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Dashboard ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
